<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:RagDemo.App.ViewModels"
             x:Class="RagDemo.App.Views.DocumentView"
             x:DataType="vm:DocumentViewModel">

    <StackPanel Spacing="12" Margin="16">

        <TextBlock Text="Document Name" FontWeight="SemiBold"/>
        <TextBox Text="{Binding DocumentName}" Watermark="e.g. company-policy.txt"/>

        <TextBlock Text="Document Text" FontWeight="SemiBold"/>
        <TextBox Text="{Binding DocumentText}"
                 Watermark="Paste document content here..."
                 AcceptsReturn="True"
                 Height="200"
                 TextWrapping="Wrap"/>

        <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Content="Add to Store"
                    Command="{Binding AddDocumentCommand}"
                    IsEnabled="{Binding !IsBusy}"/>
            <Button Content="Replace Store"
                    Command="{Binding LoadDocumentCommand}"
                    IsEnabled="{Binding !IsBusy}"/>
            <Button Content="Clear Store"
                    Command="{Binding ClearDocumentsCommand}"
                    IsEnabled="{Binding !IsBusy}"/>
            <Button Content="Refresh Status"
                    Command="{Binding RefreshStatusCommand}"
                    IsEnabled="{Binding !IsBusy}"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="Chunks in store:"/>
            <TextBlock Text="{Binding ChunkCount}" FontWeight="SemiBold"/>
        </StackPanel>

        <TextBlock Text="{Binding StatusMessage}" Foreground="Gray"/>

    </StackPanel>
</UserControl>
